DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=[your-database-password]
DB_NAME=tutoredu

# JWT Configuration - PHẢI cấu hình với giá trị mạnh trong production
JWT_SECRET=[generate-a-strong-random-secret-key-with-at-least-32-characters]
JWT_EXPIRES_IN=7d

# CORS Configuration - Danh sách các origin được phép, cách nhau bằng dấu phẩy
ALLOWED_ORIGINS=http://localhost:3000

# Server Port
PORT=3001

# Environment
NODE_ENV=development